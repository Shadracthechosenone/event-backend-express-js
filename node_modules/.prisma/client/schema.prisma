generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum ROLE {
  ADMIN
  USER
  SUPERADMIN
}

enum EventStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  COMPLETED
}

enum TicketStatus {
  PENDING // en attente de paiement
  CONFIRMED // paiement confirmé
  CANCELLED // annulé
  REFUNDED // remboursé
  USED // scanné à l'entrée
}

enum ParticipantStatus {
  REGISTERED // inscrit (événement gratuit)
  CONFIRMED // paiement confirmé
  CANCELLED // annulé
  PRESENT // présent physiquement (après scan QR)
}

enum NotificationType {
  TICKET_CONFIRMED
  EVENT_CANCELLED
  EVENT_REMINDER
  NEW_PARTICIPANT
  PAYMENT_FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CINETPAY
  ORANGE_MONEY
  MTN_MONEY
  WAVE
  STRIPE
  FREE // pour les événements gratuits
}

enum TicketItemStatus {
  ISSUED // QR généré, pas encore scanné
  USED // scanné à l'entrée
  CANCELLED // annulé (remboursement partiel, etc.)
}

// USER

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  photo     String?
  password  String
  role      ROLE     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  events              Event[] // événements créés
  sessions            Session[]
  tickets             Ticket[] // billets achetés
  participations      EventParticipant[] // participations confirmées
  notifications       Notification[]
  reviews             Review[]
  passwordResetTokens PasswordResetToken[]
  payments            Payment[]
}

// SESSION / AUTH

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String?  @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ÉVÉNEMENT

model EventCategories {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  events Event[]
}

model Event {
  id                String      @id @default(uuid())
  name              String
  description       String?
  address           String?
  latitude          Float
  longitude         Float
  startAt           DateTime
  endAt             DateTime
  favory            Boolean     @default(false)
  status            EventStatus @default(ACTIVE)
  isFree            Boolean     @default(false)
  ticketPrice       Float       @default(0) // ignoré si isFree = true
  maxCapacity       Int? // null = illimité
  eventCategoriesId Int
  capacity          Int? // nombre de place disponible (calculé automatiquement)
  userId            String // organisateur
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  category      EventCategories    @relation(fields: [eventCategoriesId], references: [id])
  organizer     User               @relation(fields: [userId], references: [id])
  images        EventImage[]
  tickets       Ticket[]
  participants  EventParticipant[]
  reviews       Review[]
  notifications Notification[]
  Payments      Payment[]

  @@index([latitude, longitude]) // accélère le filtrage par zone
  @@index([userId]) // "mes événements créés" (organisateur)
  @@index([eventCategoriesId]) // filtrage par catégorie
  @@index([status, startAt]) // "événements actifs à venir", triés par date
}

model EventImage {
  id        Int      @id @default(autoincrement())
  eventId   String
  url       String
  isPrimary Boolean  @default(false)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([eventId])
}

// TICKET (réservation + paiement)

model Ticket {
  id        String       @id @default(uuid())
  eventId   String
  userId    String
  price     Float // 0 si gratuit
  quantity  Int          @default(1)
  status    TicketStatus @default(PENDING)
  paymentId String? // référence CinetPay / Stripe
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  event   Event    @relation(fields: [eventId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  items TicketItem[] // <-- une ligne par place achetée
  // NOTE: plus de "participant" ici — EventParticipant n'est plus lié à un Ticket précis

  @@index([userId, status]) // "mes tickets en attente/confirmés"
  @@index([eventId, status]) // "tickets confirmés pour cet event" (compter les ventes)
  @@index([paymentId])
}

model TicketItem {
  id          String           @id @default(uuid(7)) // quasi-croissant : évite la fragmentation du B-tree en forte charge
  ticketId    String
  qrCode      String           @unique @default(uuid()) // contenu encodé dans le QR
  status      TicketItemStatus @default(ISSUED)
  holderName  String? // optionnel : juste pour affichage
  holderEmail String // requis : où envoyer le billet
  usedAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([holderEmail]) // "tous les billets envoyés à cet email"
}

// PARTICIPANT (lien user <-> event, indépendant du nombre de commandes)

model EventParticipant {
  id          String            @id @default(uuid())
  eventId     String
  userId      String
  status      ParticipantStatus @default(REGISTERED)
  checkedIn   Boolean           @default(false) // a scanné son QR à l'entrée
  checkedInAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId]) // 1 ligne "présence" par user, peu importe le nombre de commandes
  @@index([userId])
  @@index([eventId, status])
}

// REVIEW

model Review {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  rating    Int // 1 à 5
  comment   String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId]) // un seul avis par user par événement
  @@index([userId])
}

// NOTIFICATION

model Notification {
  id        String           @id @default(uuid())
  userId    String
  eventId   String? // optionnel, pour lier à un événement précis
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  data      Json? // metadata libre (ticketId, etc.)
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])

  @@index([userId, read]) // "mes notifications non lues", cas le plus fréquent
  @@index([eventId])
}

model Payment {
  id             String        @id @default(uuid())
  ticketId       String        @unique // 1 ticket = 1 paiement
  userId         String
  amount         Float
  eventId        String
  currency       String        @default("XOF") // Franc CFA
  status         PaymentStatus @default(PENDING)
  method         PaymentMethod
  transactionRef String?       @unique // référence retournée par CinetPay/Wave...
  failureReason  String? // message d'erreur si FAILED
  paidAt         DateTime? // null tant que pas confirmé
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  user   User     @relation(fields: [userId], references: [id])
  event  Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket Ticket[]

  @@index([userId])
  @@index([eventId])
  @@index([status, createdAt]) // dashboard admin : paiements par statut, triés par date
}
